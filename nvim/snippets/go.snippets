# comment
# snippet <trigger> <description>
# <snippet-body>
# snippet if C-style if
# if ($1)
# 	$0


snippet ir "if err not nil, return err"
	if err != nil {
		return nil, err
	}
	$0


snippet gotemp "starter file template"
	package main

	import (
		"fmt"
	)

	func main() {
		fmt.Println("Hello World!")
	}
